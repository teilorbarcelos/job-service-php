{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Total de Requisições (RPS)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(app_http_requests_total[1m])) by (method, path)",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Latência Média (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(app_http_request_duration_ms_sum[1m]) / rate(app_http_request_duration_ms_count[1m])",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Requisições por Status Code",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(app_http_requests_total) by (status)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "barAlignment": 0,
            "fillOpacity": 80,
            "pointSize": 5
          }
        }
      }
    },
    {
      "title": "Uso de Memória (RSS e Peak)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "app_process_resident_memory_bytes",
          "legendFormat": "RSS Memory",
          "refId": "A"
        },
        {
          "expr": "app_process_memory_peak_bytes",
          "legendFormat": "Peak Memory",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "title": "Uso de CPU",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "rate(app_process_cpu_seconds_total[1m])",
          "legendFormat": "CPU Usage",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        }
      }
    },
    {
      "title": "Garbage Collector (Runs e Coletas)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "app_php_gc_runs",
          "legendFormat": "GC Runs",
          "refId": "A"
        },
        {
          "expr": "app_php_gc_collected_total",
          "legendFormat": "Objetos Coletados",
          "refId": "B"
        },
        {
          "expr": "app_php_gc_threshold",
          "legendFormat": "Threshold",
          "refId": "C"
        },
        {
          "expr": "app_php_gc_roots",
          "legendFormat": "Roots",
          "refId": "D"
        }
      ]
    },
    {
      "title": "Taxa de Exceções (Por Minuto)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "rate(app_exceptions_total[1m]) * 60",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Queries no Banco (Por Minuto)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "targets": [
        {
          "expr": "rate(app_database_queries_total[1m]) * 60",
          "legendFormat": "Consultas Eloquent",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "5s",
  "schemaVersion": 36,
  "style": "dark",
