{
  "scripts": [
    {
      "name": "Install Dependencies",
      "command": "composer install"
    },
    {
      "name": "Start Infrastructure",
      "command": "make infra-up"
    },
    {
      "name": "Stop Infrastructure",
      "command": "make infra-stop"
    },
    {
      "name": "Down Infrastructure",
      "command": "make infra-down"
    },
    {
      "name": "Development Mode",
      "command": "make dev"
    },
    {
      "name": "Run Tests",
      "command": "make test"
    },
    {
      "name": "Run Coverage",
      "command": "make coverage"
    },
    {
      "name": "Generate Job",
      "command": "make generate-job"
    },
    {
      "name": "SonarQube Scan",
      "command": "make sonar"
    }
  ],
  "replacements": [
    {
      "path": "composer.json",
      "pattern": "job-service-php"
    }
  ]
}
