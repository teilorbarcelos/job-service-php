{
  "name": "backend-php-slim",
  "version": "1.0.0",
  "description": "Backend PHP Slim with Githooks",
  "scripts": {
    "prepare": "husky",
    "lint": "vendor/bin/phpstan analyse src",
    "test": "vendor/bin/phpunit --coverage-text",
    "build": "docker build -t backend-php-slim ."
  },
  "devDependencies": {
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0"
  },
  "lint-staged": {
    "*.php": [
      "vendor/bin/phpstan analyse"
    ]
  }
}
