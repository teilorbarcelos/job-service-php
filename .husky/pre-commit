#!/bin/bash

# 1. Verificar tipagem e erros estáticos (PHPStan Level 9)
echo "Checking types and static analysis (PHPStan)..."
make lint

if [ $? -ne 0 ]; then
    echo "#######################################################"
    echo "# COMMIT BLOQUEADO: Erros de tipagem encontrados!     #"
    echo "#######################################################"
    exit 1
fi

# 2. Executar testes e verificar cobertura
echo "Running tests and checking coverage..."
make coverage

RESULT=$?

if [ $RESULT -ne 0 ]; then
    echo "#######################################################"
    echo "# COMMIT BLOQUEADO: Testes falharam ou cobertura < 100% #"
    echo "#######################################################"
    exit 1
fi

echo "Testes e cobertura OK. Prosseguindo com o commit..."
exit 0
