{
    "name": "teilorbarcelos/job-service-php",
    "description": "Gold Standard PHP Slim 4 Backend",
    "type": "project",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Teilor Barcelos",
            "email": "teilorbarcelos@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.3",
        "guzzlehttp/guzzle": "^7.10",
        "illuminate/database": "^11.0",
        "illuminate/events": "^11.0",
        "illuminate/pagination": "^11.51",
        "lcobucci/clock": "^3.6",
        "lcobucci/jwt": "^5.2",
        "league/flysystem": "^3.0",
        "league/flysystem-local": "^3.0",
        "monolog/monolog": "^3.5",
        "php-amqplib/php-amqplib": "^3.7",
        "php-di/php-di": "^7.0",
        "promphp/prometheus_client_php": "^2.15",
        "ramsey/uuid": "^4.9",
        "respect/validation": "^2.3",
        "slim/psr7": "^1.6",
        "slim/slim": "^4.13",
        "symfony/mailer": "^8.0",
        "symfony/mime": "^8.0",
        "vlucas/phpdotenv": "^5.6",
        "zircote/swagger-php": "^4.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.10",
        "robmorgan/phinx": "^0.15.0"
    },
    "config": {
        "process-timeout": 0,
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        },
        "platform": {
            "php": "8.4.0"
        }
    },
    "scripts": {
        "start": "php -S 0.0.0.0:8888 -t public",
        "dev": "php -S 0.0.0.0:8888 -t public",
        "test": "phpunit",
        "lint": "phpstan analyse src"
    }
}
