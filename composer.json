{
    "name": "teilorbarcelos/job-service-php",
    "description": "Job runner boilerplate (cron + PostgreSQL + Redis + RabbitMQ)",
    "type": "project",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        },
        "files": [
            "src/Jobs/register-jobs.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Teilor Barcelos",
            "email": "teilorbarcelos@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.3",
        "ext-pcntl": "*",
        "ext-pdo": "*",
        "dragonmantank/cron-expression": "^3.4",
        "illuminate/database": "^11.0",
        "monolog/monolog": "^3.5",
        "php-amqplib/php-amqplib": "^3.7",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.10"
    },
    "config": {
        "process-timeout": 0,
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        },
        "platform": {
            "php": "8.3.31"
        }
    },
    "scripts": {
        "start": "php src/Application.php",
        "dev": "php -d display_errors=1 src/Application.php",
        "test": "phpunit",
        "lint": "phpstan analyse src --memory-limit=-1"
    }
}
