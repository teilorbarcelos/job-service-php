# ============================================================
# Job Service PHP — Produção
# ============================================================
# Copie este arquivo para .env e preencha TODOS os placeholders.
# NUNCA use valores de desenvolvimento em produção.
# ============================================================

APP_ENV=production
APP_DEBUG=false
LOG_LEVEL=info
SHUTDOWN_TIMEOUT_MS=30000
JOB_EXECUTION_TIMEOUT_MS=300000

# Database PostgreSQL
DB_DRIVER=pgsql
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=backend_php_slim_db
DB_USERNAME=postgres
DB_PASSWORD=<SUA-SENHA-AQUI>

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ
MESSAGING_ENABLED=true
RABBIT_HOST=localhost
RABBIT_PORT=5672
RABBIT_USER=guest
RABBIT_PASSWORD=<SENHA-RABBIT-AQUI>

# Jobs
HEALTH_CHECK_CRON=*/1 * * * *
HEALTH_CHECK_ENABLED=true
