# ============================================================
# Backend PHP Slim — Produção
# ============================================================
# Copie este arquivo para .env e preencha TODOS os placeholders.
# NUNCA use valores de desenvolvimento em produção.
# ============================================================

# --- App ---
APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://seudominio.com
APP_VERSION=1.0.0
APP_DEPLOY_TIMESTAMP=2026-06-08T00:00:00Z

# --- Auth (CRÍTICO) ---
# Gere um UUID v4 ou string aleatória de 32+ caracteres.
# Exemplo: openssl rand -hex 32
JWT_SECRET=<GERAR-STRING-32-CHAR-AQUI>
JWT_EXPIRATION=3600

# --- Database PostgreSQL ---
DB_DRIVER=pgsql
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=backend_php_slim_db
DB_USERNAME=postgres
DB_PASSWORD=<SUA-SENHA-AQUI>
DB_CHARSET=utf8

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Rate Limit ---
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=60

# --- Admin inicial (primeiro deploy apenas) ---
# Após criar o admin, remova ou comente estas linhas.
FIRST_USER=admin@email.com
FIRST_PASSWORD=<SENHA-FORTE-AQUI>

# --- SMTP (obrigatório para email recovery) ---
SMTP_HOST=smtp.seuprovedor.com
SMTP_PORT=587
SMTP_USER=<USUARIO-SMTP>
SMTP_PASS=<SENHA-SMTP>
SMTP_FROM=noreply@seudominio.com

# --- RabbitMQ (obrigatório para audit assíncrono) ---
MESSAGING_ENABLED=true
AUDIT_ASYNC=true
EMAIL_ASYNC=true
ERROR_LOG_ASYNC=true
RABBIT_HOST=localhost
RABBIT_PORT=5672
RABBIT_USER=guest
RABBIT_PASSWORD=<SENHA-RABBIT-AQUI>

# --- Storage ---
STORAGE_DISK=local
STORAGE_PATH=/app/storage/app
STORAGE_URL=https://seudominio.com/storage

# --- PDF Service (opcional) ---
PDF_SERVICE_URL=http://localhost:8889

# --- Métricas ---
# Gere um token aleatório. Exemplo: openssl rand -hex 16
METRICS_TOKEN=<GERAR-TOKEN-ALEATORIO-AQUI>

# --- Body size limit ---
REQUEST_BODY_MAX_SIZE=2M
