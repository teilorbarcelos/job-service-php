# App
AUTH_MODE=local # local | remote — when remote, /v1/auth/* returns 404 (handled by auth-service-php)
APP_ENV=development
APP_DEBUG=true
APP_VERSION=1.0.0
APP_DEPLOY_TIMESTAMP=2026-04-29T18:00:00Z
APP_URL=http://localhost:8888
JWT_SECRET=86941813-8b97-4cad-b0b2-f97734a947d7

# Database
DB_DRIVER=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=backend_php_slim_db
DB_USERNAME=postgres
DB_PASSWORD=postgrespw
DB_CHARSET=utf8

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# First User
FIRST_USER=admin@email.com
FIRST_PASSWORD=admin@123
# SMTP Config
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@example.com

# RabbitMQ
MESSAGING_ENABLED=false
AUDIT_ASYNC=false
RABBIT_HOST=rabbitmq
RABBIT_PORT=5672
RABBIT_USER=guest
RABBIT_PASSWORD=guest

# Storage
STORAGE_DISK=local
STORAGE_PATH=/app/storage/app
STORAGE_URL=http://localhost:8888/storage
PDF_SERVICE_URL=http://host.docker.internal:8889
